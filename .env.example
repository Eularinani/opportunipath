# ─── Base de Dados (Neon PostgreSQL) ─────────────────────────────────────────
# Obtém em: https://neon.tech → New Project → Connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── NextAuth.js v5 ───────────────────────────────────────────────────────────
# Gera com: openssl rand -base64 32
AUTH_SECRET="gera_um_secret_seguro_aqui"
NEXTAUTH_URL="http://localhost:3000"

# ─── Resend (Newsletter & Email) ──────────────────────────────────────────────
# Obtém em: https://resend.com → API Keys
RESEND_API_KEY="re_xxxxxxxxxx"

# ─── Admin ────────────────────────────────────────────────────────────────────
# Email para notificações de novos contactos
ADMIN_EMAIL="admin@opportunipath.ao"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Google Cloud Translation (opcional) ──────────────────────────────────────
# Usado para traduzir bolsas importadas automaticamente.
# Cria uma API key em: https://cloud.google.com/translate
GOOGLE_CLOUD_TRANSLATE_API_KEY=""
